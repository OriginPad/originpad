# Chain: "testnet" or "mainnet"
CHAIN=testnet

# Oracle wallet private key (funded with ETH for gas)
ORACLE_PRIVATE_KEY=0x...

# Contract addresses (from deploy output)
VAULT_ADDRESS=0x...
LAUNCHPAD_ADDRESS=0x...

# RPC endpoint. IMPORTANT: must support eth_getLogs (filtered). Anonymous public
# endpoints (publicnode/base.org/drpc) rate-limit or break under load — for mainnet
# use a keyed provider (Alchemy/Infura/QuickNode free tier). publicnode getLogs is broken.
RPC_URL=https://sepolia.base.org

# Indexer tuning (incremental: persists checkpoint, only scans new blocks each cycle).
# LOG_CHUNK = max block span per getLogs (drpc caps ~10000; Alchemy 10000; base.org 2000).
# INDEX_LOOKBACK_BLOCKS = one-time bootstrap depth on first run (no checkpoint yet).
# RPC_DELAY_MS = throttle between getLogs calls to stay under free-tier rate limits.
LOG_CHUNK=10000
INDEX_LOOKBACK_BLOCKS=80000
RPC_DELAY_MS=40
